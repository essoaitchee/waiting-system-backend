<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.waitingsystem.repository.ProductRepository">

	<resultMap id="ProductResultMap" type="com.example.waitingsystem.domain.Product">
		<id property="productId" column="product_id"/>
		<result property="categoryId" column="category_id"/>
		<result property="productName" column="product_name"/>
		<result property="price" column="price"/>
		<result property="stockCount" column="stock_count"/>
		<result property="status" column="status"/>
		<result property="createdAt" column="created_at"/>
		<result property="updatedAt" column="updated_at"/>
	</resultMap>

	<select id="findProducts" resultMap="ProductResultMap">
		SELECT product_id,
		       category_id,
		       product_name,
		       price,
		       stock_count,
		       status,
		       created_at,
		       updated_at
		FROM product
		WHERE status = 'ACTIVE'
		<if test="categoryId != null">
			AND category_id = #{categoryId}
		</if>
		ORDER BY product_id DESC
		LIMIT #{size} OFFSET #{offset}
	</select>

	<select id="findActiveCategoryIds" resultType="long">
		SELECT DISTINCT category_id
		FROM product
		WHERE status = 'ACTIVE'
		ORDER BY category_id
	</select>
</mapper>
